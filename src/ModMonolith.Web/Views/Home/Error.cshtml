@{
    ViewData["Title"] = "Error";
}

<div class="page-shell">
    <section class="card">
        <div class="section-head">
            <div>
                <p class="section-kicker">Application Error</p>
                <h2>Something went wrong.</h2>
            </div>
        </div>
        <p class="lede">The request could not be completed. Review the application logs for the underlying exception.</p>
        <a class="button" asp-controller="Home" asp-action="Index">Return to the dashboard</a>
    </section>
</div>
